<% layout("/layouts/boilerplates") -%>

<div class="container mt-5 mb-5">
  <div class="row justify-content-center">

    <div class="col-md-7">

      <div class="card shadow border-0 rounded-4">
        <div class="card-body px-4 py-4">

          <h4 class="fw-bold mb-2">Confirm Your Stay</h4>
          <p class="text-muted"><%= listing.title %></p>

          <img src="<%= listing.image.url %>" class="img-fluid rounded mb-3"
               style="height:220px; object-fit:cover; width:100%;">

          <p>Price: <b>₹ <%= listing.price %> / night</b></p>

          <form action="/book/<%= listing._id %>" method="POST">

            <div class="mb-3">
              <label class="form-label">Check-in Date</label>
              <input type="date" name="checkIn" class="form-control" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Check-out Date</label>
              <input type="date" name="checkOut" class="form-control" required>
            </div>

            <button class="btn btn-danger w-100 mt-2">
              Confirm Booking
            </button>

          </form>

        </div>
      </div>

    </div>

  </div>
</div>
